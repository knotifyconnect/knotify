{$API_DOMAIN} {
    encode zstd gzip

    reverse_proxy 127.0.0.1:3001 {
        health_uri /health
        health_interval 30s
        health_timeout 5s
    }

    header {
        -Server
        X-Content-Type-Options nosniff
        Referrer-Policy no-referrer
        Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
    }

    log
}

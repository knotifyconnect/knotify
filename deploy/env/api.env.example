NODE_ENV=production
HOST=127.0.0.1
PORT=3001

# Exact comma-separated browser origins. Do not use *.
ALLOWED_ORIGIN=https://app.example.com
PUBLIC_WEB_URL=https://app.example.com

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVER_ONLY_SECRET
DATABASE_URL=REPLACE_IF_REQUIRED_BY_EXISTING_ROUTES

ADMIN_PANEL_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
RESEND_API_KEY=REPLACE_IF_EMAIL_IS_ENABLED
ANTHROPIC_API_KEY=REPLACE_WITH_SERVER_ONLY_SECRET

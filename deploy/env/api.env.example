LOCAL_AI_PROVIDER=ollama
LOCAL_AI_BASE_URL=http://127.0.0.1:11434
LOCAL_AI_DOCUMENT_MODEL=qwen2.5:7b-instruct
LOCAL_AI_TIMEOUT_MS=90000
LOCAL_AI_MAX_CONCURRENCY=1

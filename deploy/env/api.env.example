NODE_ENV=production
HOST=127.0.0.1
PORT=3001

# Exact comma-separated browser origins. Do not use *.
ALLOWED_ORIGIN=https://app.example.com
PUBLIC_WEB_URL=https://app.example.com

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVER_ONLY_SECRET
DATABASE_URL=REPLACE_IF_REQUIRED_BY_EXISTING_ROUTES

ADMIN_PANEL_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
RESEND_API_KEY=REPLACE_IF_EMAIL_IS_ENABLED
# Used only by the Layer 2 relationship-insight cache (relationshipPriority.ts).
# Degrades gracefully to deterministic text if unset or out of credit.
ANTHROPIC_API_KEY=REPLACE_IF_LAYER2_INSIGHTS_ENABLED
# Companion chat (companion.ts) — free-tier Google Gemini, get a key at
# https://aistudio.google.com/apikey (no card required).
GEMINI_API_KEY=REPLACE_WITH_SERVER_ONLY_SECRET
# COMPANION_MODEL=gemini-2.5-flash
# COMPANION_FREE_DAILY_LIMIT=10
# COMPANION_PREMIUM_DAILY_LIMIT=100

LOCAL_AI_PROVIDER=ollama
LOCAL_AI_BASE_URL=http://127.0.0.1:11434
LOCAL_AI_DOCUMENT_MODEL=qwen2.5:7b-instruct
LOCAL_AI_TIMEOUT_MS=90000
LOCAL_AI_MAX_CONCURRENCY=1
# LOCAL_AI_CHAT_MODEL=
# LOCAL_AI_EMBEDDING_MODEL=
# LOCAL_AI_AUTH_TOKEN=

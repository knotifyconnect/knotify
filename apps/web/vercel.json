{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/main?__path=$1" },
    { "source": "/((?!api(?:/|$)|guides(?:/|$)).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/main.ts": {
      "includeFiles": "../api/dist/**",
      "maxDuration": 30
    }
  }
}

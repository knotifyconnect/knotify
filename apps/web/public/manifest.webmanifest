{
  "id": "/",
  "name": "knotify · Networks worth keeping",
  "short_name": "knotify",
  "description": "Keep valuable professional relationships warm and turn trust into real opportunities.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#F4EFE6",

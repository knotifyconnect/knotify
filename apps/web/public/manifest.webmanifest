  "icons": [
    { "src": "/app-icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/app-icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/app-icon-maskable-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "shortcuts": [
    { "name": "Your Knot", "url": "/map", "icons": [{ "src": "/app-icon-192.png", "sizes": "192x192" }] },
    { "name": "Messages", "url": "/messages", "icons": [{ "src": "/app-icon-192.png", "sizes": "192x192" }] },
    { "name": "Jobs", "url": "/jobs", "icons": [{ "src": "/app-icon-192.png", "sizes": "192x192" }] }
  ]

{
  "name": "@nodenet/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js",
      "default": "./dist/app.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "seed:test-users": "tsx src/scripts/seedTestUsers.ts",
    "seed:demo-auth-users": "tsx src/scripts/seedDemoAuthUsers.ts",
    "seed:hr-demo-data": "tsx src/scripts/seedHrDemoData.ts",
    "smoke:referral-flow": "tsx src/scripts/smokeReferralFlow.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'No lint configured for api'",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@nodenet/shared": "file:../../packages/shared",
    "@supabase/supabase-js": "^2.50.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
